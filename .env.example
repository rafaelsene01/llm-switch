# ─── GATEWAY ─────────────────────────────────────────────────────────────────
PORT=3000

# API keys internas que seus sistemas/usuários vão usar para acessar o gateway
# Gere com: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
GATEWAY_KEYS=key_dev_abc123,key_rh_xyz789,key_producao_qwerty

# Mapeia cada key ao seu dono (departamento/sistema) — usado nos logs de auditoria
GATEWAY_KEY_LABELS={"key_dev_abc123":"time-dev","key_rh_xyz789":"rh","key_producao_qwerty":"producao"}

# Provider padrão quando o cliente não especifica (formato: provider:modelo)
DEFAULT_PROVIDER=openai:gpt-4o-mini

# ─── RATE LIMIT ───────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000   # 1 minuto
RATE_LIMIT_MAX=30            # máx. 30 requisições por minuto por cliente

# ─── SANITIZAÇÃO CUSTOMIZADA ─────────────────────────────────────────────────
# Termos proprietários a bloquear (separados por vírgula)
# Ex: nomes de projetos internos, clientes, tecnologias sigilosas
GATEWAY_BLOCKLIST=Projeto Phoenix,Cliente XYZ,Operação Sirio

# ─── PROVIDERS EXTERNOS (só o gateway conhece essas chaves) ──────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=AIza...
MISTRAL_API_KEY=...
OPENROUTER_API_KEY=sk-or-...

# ─── LOGS ─────────────────────────────────────────────────────────────────────
LOG_LEVEL=info   # debug | info | warn | error
