# ─── GATEWAY ─────────────────────────────────────────────────────────────────
PORT=3000
NEXT_PUBLIC_GATEWAY_URL=http://localhost:3000

# ─── RATE LIMIT ───────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=1200000   # 1 minuto
RATE_LIMIT_MAX=30            # máx. 30 requisições por minuto por cliente


# ─── LOGS ─────────────────────────────────────────────────────────────────────
LOG_LEVEL=info   # debug | info | warn | error
