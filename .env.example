# ─── GATEWAY ─────────────────────────────────────────────────────────────────
PORT=3000
NEXT_PUBLIC_GATEWAY_URL=http://localhost:3000

# ─── RATE LIMIT ───────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000   # 1 minuto
RATE_LIMIT_MAX=30            # máx. 30 requisições por minuto por cliente

# ─── PROVIDERS EXTERNOS (só o gateway conhece essas chaves) ──────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=AIza...
MISTRAL_API_KEY=...
OPENROUTER_API_KEY=sk-or-...

# ─── LOGS ─────────────────────────────────────────────────────────────────────
LOG_LEVEL=info   # debug | info | warn | error
