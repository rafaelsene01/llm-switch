{
  "name": "llm-switch",
  "version": "2.0.0",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "predev": "kill-port 3000",
    "dev": "nx run-many --targets=serve,dev --parallel=true",
    "build": "nx run-many --target=build",
    "lint": "nx run-many --target=lint",
    "test": "nx run-many --target=test",
    "api:serve": "nx run api:serve",
    "api:build": "nx run api:build",
    "web:dev": "nx run web:dev",
    "web:build": "nx run web:build"
  },
  "devDependencies": {
    "@nx/esbuild": "^20.0.0",
    "@nx/eslint": "^20.0.0",
    "@nx/jest": "^20.0.0",
    "@nx/js": "^20.0.0",
    "@nx/next": "^20.0.0",
    "@nx/node": "^20.0.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.0.0",
    "@types/uuid": "^10.0.0",
    "esbuild": "^0.23.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "nx": "^20.0.0",
    "patch-package": "^8.0.1",
    "prettier": "^3.3.0",
    "shadcn": "^4.3.1",
    "ts-jest": "^29.2.0",
    "ts-node": "^10.9.2",
    "tsc": "^2.0.4",
    "typescript": "^5.4.0"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "better-sqlite3",
      "esbuild",
      "nx",
      "sharp"
    ],
    "overrides": {
      "next": "15.2.4"
    }
  }
}
